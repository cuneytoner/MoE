# ==============================================================================
# File: .gitignore
# Description: Global exclusion rules for Git tracking and deployment stages.
# ==============================================================================

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv*/
.env/
env/

# Environment and sensitive tokens
.env
*.local

# System and logs
*.log
.DS_Store
.aider*

# Front-end dependencies & build outputs
node_modules/
dist/
.html
