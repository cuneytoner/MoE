{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:moe:animation-plan-schema:1.0",
  "title": "MoE Animation Plan Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_id",
    "title",
    "description",
    "mode",
    "visual_reference_only",
    "structural_certification",
    "operator_review_required",
    "timeline",
    "scene",
    "tracks",
    "outputs",
    "safety"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "plan_id": {
      "$ref": "#/$defs/safeIdentifier"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "description": {
      "type": "string",
      "maxLength": 1000
    },
    "mode": {
      "type": "string",
      "enum": [
        "dry_run"
      ]
    },
    "visual_reference_only": {
      "type": "boolean",
      "const": true
    },
    "structural_certification": {
      "type": "boolean",
      "const": false
    },
    "operator_review_required": {
      "type": "boolean",
      "const": true
    },
    "timeline": {
      "$ref": "#/$defs/timeline"
    },
    "scene": {
      "$ref": "#/$defs/scene"
    },
    "tracks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "$ref": "#/$defs/track"
      }
    },
    "outputs": {
      "$ref": "#/$defs/outputs"
    },
    "safety": {
      "$ref": "#/$defs/safety"
    }
  },
  "$defs": {
    "safeIdentifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[a-z0-9][a-z0-9_-]*$",
      "$comment": "Rejects path separators, traversal, whitespace, hidden ids, URLs, drive prefixes, and absolute paths by allowing only lowercase ids beginning with an alphanumeric character."
    },
    "safeReferenceId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9 _:-]*$",
      "not": {
        "anyOf": [
          { "pattern": "/" },
          { "pattern": "\\\\" },
          { "pattern": "\\.\\." },
          { "pattern": "://" },
          { "pattern": "^[A-Za-z]:" },
          { "pattern": "^//" },
          { "pattern": "^/home/" },
          { "pattern": "^/mnt/" },
          { "pattern": "^/media/" },
          { "pattern": "^/workspace/" },
          { "pattern": "^/app/" }
        ]
      },
      "$comment": "M36.2 semantic validation must perform final filesystem/symlink/runtime reference checks."
    },
    "vector3": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "number"
      }
    },
    "runtimeRelativePreviewPath": {
      "type": "string",
      "pattern": "^media/animation/previews/[a-z0-9][a-z0-9_-]*\\.(mp4|webm|gif)$",
      "not": {
        "anyOf": [
          { "pattern": "^/" },
          { "pattern": "\\.\\." },
          { "pattern": "\\\\" },
          { "pattern": "://" },
          { "pattern": "^[A-Za-z]:" },
          { "pattern": "^/home/" },
          { "pattern": "^/mnt/" },
          { "pattern": "^/media/cuneyt/" },
          { "pattern": "^/workspace/" },
          { "pattern": "^/app/" }
        ]
      }
    },
    "runtimeRelativeMetadataPath": {
      "type": "string",
      "pattern": "^media/animation/metadata/[a-z0-9][a-z0-9_-]*\\.json$",
      "not": {
        "anyOf": [
          { "pattern": "^/" },
          { "pattern": "\\.\\." },
          { "pattern": "\\\\" },
          { "pattern": "://" },
          { "pattern": "^[A-Za-z]:" },
          { "pattern": "^/home/" },
          { "pattern": "^/mnt/" },
          { "pattern": "^/media/cuneyt/" },
          { "pattern": "^/workspace/" },
          { "pattern": "^/app/" }
        ]
      }
    },
    "timeline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fps",
        "start_frame",
        "end_frame",
        "duration_seconds"
      ],
      "properties": {
        "fps": {
          "type": "integer",
          "minimum": 1,
          "maximum": 120
        },
        "start_frame": {
          "type": "integer",
          "minimum": 0
        },
        "end_frame": {
          "type": "integer",
          "minimum": 1
        },
        "duration_seconds": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 86400
        }
      },
      "$comment": "M36.2 semantic validation must check end_frame > start_frame and duration/fps consistency."
    },
    "scene": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_scene",
        "units"
      ],
      "properties": {
        "source_scene": {
          "$ref": "#/$defs/sceneSource"
        },
        "units": {
          "type": "string",
          "enum": [
            "meters",
            "centimeters",
            "millimeters"
          ]
        }
      }
    },
    "sceneSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "reference_id"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "existing_runtime_3d_asset"
          ]
        },
        "reference_id": {
          "$ref": "#/$defs/safeReferenceId"
        }
      }
    },
    "keyframe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "frame"
      ],
      "properties": {
        "frame": {
          "type": "integer",
          "minimum": 0
        },
        "location": {
          "$ref": "#/$defs/vector3"
        },
        "rotation_euler": {
          "$ref": "#/$defs/vector3"
        },
        "scale": {
          "$ref": "#/$defs/vector3"
        },
        "visibility": {
          "type": "boolean"
        }
      },
      "anyOf": [
        { "required": ["location"] },
        { "required": ["rotation_euler"] },
        { "required": ["scale"] },
        { "required": ["visibility"] }
      ],
      "$comment": "M36.2 semantic validation must check property/keyframe value compatibility, duplicate frames, and ordering."
    },
    "track": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "track_id",
        "target_type",
        "target_id",
        "property",
        "interpolation",
        "keyframes"
      ],
      "properties": {
        "track_id": {
          "$ref": "#/$defs/safeIdentifier"
        },
        "target_type": {
          "type": "string",
          "enum": [
            "camera",
            "object"
          ]
        },
        "target_id": {
          "$ref": "#/$defs/safeReferenceId"
        },
        "property": {
          "type": "string",
          "enum": [
            "transform",
            "location",
            "rotation_euler",
            "scale",
            "visibility"
          ]
        },
        "interpolation": {
          "type": "string",
          "enum": [
            "constant",
            "linear",
            "bezier"
          ]
        },
        "keyframes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1000,
          "items": {
            "$ref": "#/$defs/keyframe"
          }
        }
      },
      "$comment": "M36.2 semantic validation must check duplicate track_id, target resolution, duplicate frames, and property/keyframe compatibility."
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preview",
        "metadata"
      ],
      "properties": {
        "preview": {
          "$ref": "#/$defs/previewOutput"
        },
        "metadata": {
          "$ref": "#/$defs/metadataOutput"
        }
      }
    },
    "previewOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "format",
        "relative_runtime_path"
      ],
      "properties": {
        "enabled": {
          "type": "boolean",
          "const": false
        },
        "format": {
          "type": "string",
          "enum": [
            "mp4",
            "webm",
            "gif"
          ]
        },
        "relative_runtime_path": {
          "$ref": "#/$defs/runtimeRelativePreviewPath"
        }
      }
    },
    "metadataOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relative_runtime_path"
      ],
      "properties": {
        "relative_runtime_path": {
          "$ref": "#/$defs/runtimeRelativeMetadataPath"
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "real_animation_enabled",
        "blender_execution_enabled",
        "preview_render_enabled",
        "source_assets_modified",
        "runtime_write_planned"
      ],
      "properties": {
        "real_animation_enabled": {
          "type": "boolean",
          "const": false
        },
        "blender_execution_enabled": {
          "type": "boolean",
          "const": false
        },
        "preview_render_enabled": {
          "type": "boolean",
          "const": false
        },
        "source_assets_modified": {
          "type": "boolean",
          "const": false
        },
        "runtime_write_planned": {
          "type": "boolean",
          "const": false
        }
      }
    }
  }
}
